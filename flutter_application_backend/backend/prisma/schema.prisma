generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Roupas {
  id          Int     @id @default(autoincrement())
  img         String
  nome        String
  categoria   String
  preco       Decimal @db.Decimal(10,2)
  marca       String
}